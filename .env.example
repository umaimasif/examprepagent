# ---- Groq (LLM chat + Whisper transcription) ----
# Get a free key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3

# ---- MongoDB Atlas (progress + RAG vectors) ----
# Get a free cluster: https://www.mongodb.com/atlas
MONGODB_URI=
MONGODB_DB=examprep

# ---- Embeddings (Groq has none -> Jina free API) ----
# Get a free key: https://jina.ai/embeddings
EMBEDDINGS_PROVIDER=jina
JINA_API_KEY=
JINA_MODEL=jina-embeddings-v3
EMBEDDING_DIM=1024

# ---- Atlas Vector Search index name (create it in the Atlas UI) ----
VECTOR_INDEX_NAME=vector_index

# ---- Transcript on serverless (YouTube blocks Vercel IPs) ----
# Supadata fetches YouTube server-side, so it works on Vercel. Free tier.
# Get a free key: https://supadata.ai
SUPADATA_API_KEY=

